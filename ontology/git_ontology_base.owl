                <owl:onClass rdf:resource="http://gitontologic/knowledgerep/git#Tag"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
        <rdfs:range>
            <owl:Restriction>
