            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#User"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#contributesTo"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://gitontologic/knowledgerep/git#contributesTo -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#contributesTo">
        <owl:inverseOf rdf:resource="http://gitontologic/knowledgerep/git#hasContributors"/>
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#User"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#contributesTo"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#hasContributors"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#User"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#hasBranch"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://gitontologic/knowledgerep/git#Branch"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://gitontologic/knowledgerep/git#fileOfRepo -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#fileOfRepo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#File"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#fileOfRepo"/>
