<?xml version="1.0"?>
<rdf:RDF xmlns="http://gitontologic/knowledgerep/git#"
     xml:base="http://gitontologic/knowledgerep/git"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrl2="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://gitontologic/knowledgerep/git"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://gitontologic/knowledgerep/git#authoredBy -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#authoredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#authoredBy"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#User"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#committedBy"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#User"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#onBranch"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Branch"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#taggedAs"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://gitontologic/knowledgerep/git#Tag"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#User"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#contributesTo"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://gitontologic/knowledgerep/git#belongsToRepo -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#belongsToRepo">
        <owl:inverseOf rdf:resource="http://gitontologic/knowledgerep/git#hasBranch"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#Branch"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#belongsToRepo"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#ownsCommit"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#hasContributors"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#User"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#hasBranch"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://gitontologic/knowledgerep/git#Branch"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://gitontologic/knowledgerep/git#committedBy -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#committedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
        <rdfs:domain>
            <owl:Restriction>
