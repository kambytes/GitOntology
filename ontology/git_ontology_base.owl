    <!-- http://gitontologic/knowledgerep/git#ownsCommit -->

    <owl:ObjectProperty rdf:about="http://gitontologic/knowledgerep/git#ownsCommit">
        <rdfs:domain rdf:resource="http://gitontologic/knowledgerep/git#Branch"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#belongsToRepo"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Repository"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://gitontologic/knowledgerep/git#ownsCommit"/>
                <owl:someValuesFrom rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://gitontologic/knowledgerep/git#Commit"/>
