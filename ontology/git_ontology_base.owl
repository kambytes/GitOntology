    <!-- http://gitontologic/knowledgerep/git#InitialCommit -->

    <owl:Class rdf:about="http://gitontologic/knowledgerep/git#InitialCommit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://gitontologic/knowledgerep/git#Commit"/>
                    <owl:Restriction>
